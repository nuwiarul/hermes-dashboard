# Frontend Environment Variables
# Copy this file to .env and fill in the values
# DO NOT commit .env to git!

# ============================================================
# API CONFIGURATION
# ============================================================
# Backend API URL (your backend server)
PUBLIC_API_BASE_URL=https://api-hermes.vinrul.my.id

# ============================================================
# APP CONFIGURATION
# ============================================================
# App name (displayed in UI)
PUBLIC_APP_NAME=Hermes Dashboard

# App version
PUBLIC_APP_VERSION=0.1.0

# ============================================================
# DEVELOPMENT
# ============================================================
# Enable/disable features in development
PUBLIC_DEV_MODE=false

# Mock API responses (for development without backend)
PUBLIC_MOCK_API=false
