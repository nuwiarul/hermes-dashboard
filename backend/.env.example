# Hermes Dashboard Backend Configuration

# Hermes home directory (default: ~/.hermes)
HERMES_HOME=/home/ubuntu/.hermes

# Server port (default: 3001)
PORT=3001

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=https://hermes.vinrul.my.id

# JWT secret for authentication (generate a strong random string for production)
JWT_SECRET=change-me-to-a-strong-random-string

# JWT token durations (in minutes for access, days for refresh)
JWT_ACCESS_DURATION=15
JWT_REFRESH_DURATION=7
