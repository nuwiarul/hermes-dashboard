# Backend Environment Variables
# Copy this file to .env and fill in the values
# DO NOT commit .env to git!

# ============================================================
# SERVER
# ============================================================
PORT=3001
HOST=0.0.0.0
RUST_LOG=info

# ============================================================
# HERMES
# ============================================================
# Path to Hermes home directory (default: ~/.hermes)
HERMES_HOME=/home/ubuntu/.hermes

# ============================================================
# AUTHENTICATION
# ============================================================
# Dashboard login credentials
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=your-strong-password-here

# JWT Secrets (generate with: openssl rand -hex 32)
JWT_ACCESS_SECRET=your-access-token-secret-here
JWT_REFRESH_SECRET=your-refresh-token-secret-here

# Token TTL (in seconds)
ACCESS_TOKEN_TTL=900          # 15 minutes
REFRESH_TOKEN_TTL=604800      # 7 days

# ============================================================
# COOKIE
# ============================================================
# Cookie domain (must start with dot for subdomain support)
# Example: .vinrul.my.id (works for hermes.vinrul.my.id AND api-hermes.vinrul.my.id)
COOKIE_DOMAIN=.vinrul.my.id

# Cookie secure (set to true for HTTPS, false for local development)
COOKIE_SECURE=true

# ============================================================
# CORS
# ============================================================
# Allowed origin for CORS (your frontend URL)
# Must be specific domain, NOT wildcard (*)
CORS_ORIGIN=https://hermes.vinrul.my.id

# Allow credentials (required for cookies)
CORS_ALLOW_CREDENTIALS=true

# ============================================================
# FRONTEND
# ============================================================
# Frontend URL (for validation and redirects)
FRONTEND_URL=https://hermes.vinrul.my.id

# Frontend domain (for origin validation)
FRONTEND_DOMAIN=hermes.vinrul.my.id

# ============================================================
# BACKEND
# ============================================================
# Backend URL (for self-reference if needed)
BACKEND_URL=https://api-hermes.vinrul.my.id

# Backend domain (for origin validation)
BACKEND_DOMAIN=api-hermes.vinrul.my.id

# ============================================================
# RATE LIMITING
# ============================================================
# Login rate limit (attempts per minute per IP)
RATE_LIMIT_LOGIN=5

# Refresh rate limit (attempts per minute per IP)
RATE_LIMIT_REFRESH=10

# General API rate limit (requests per minute per IP)
RATE_LIMIT_API=100

# ============================================================
# DATABASE
# ============================================================
# SQLite database path (default: HERMES_HOME/state.db)
DATABASE_PATH=/home/ubuntu/.hermes/state.db

# ============================================================
# SSL (if not using Nginx)
# ============================================================
# SSL certificate paths (for direct HTTPS in Rust)
# SSL_CERT_PATH=/etc/ssl/vinrul_my_id_cert.pem
# SSL_KEY_PATH=/etc/ssl/vinrul_my_id_key.pem
